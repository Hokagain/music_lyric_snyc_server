<Window x:Class="music_lyric_snyc_server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:music_lyric_snyc_server.Behaviors"
        mc:Ignorable="d"
        Title="QQ音乐歌词同步" Height="760" Width="1080" MinWidth="920" MinHeight="620">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="190" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Background="#F5F5F5" Padding="12">
                <StackPanel>
                    <Border Height="280" CornerRadius="10" ClipToBounds="True" Background="#E6E6E6">
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill" />
                    </Border>

                    <TextBlock Margin="0,12,0,0" Text="{Binding SongTitle}" FontWeight="SemiBold" FontSize="20" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding Artist}" Foreground="#555" FontSize="14" TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding PlaybackStatus}" Foreground="#222" FontSize="14" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding ProgressText}" Foreground="#222" FontSize="14" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Background="#FAFAFA" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="当前歌词" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2" Text="{Binding CurrentLyric}" FontSize="24" TextWrapping="Wrap" Foreground="#1F1F1F" />

                    <Border Grid.Row="4" CornerRadius="8" Background="White" Padding="8">
                        <ListBox ItemsSource="{Binding LyricLines}"
                                 SelectedIndex="{Binding CurrentLyricIndex, Mode=OneWay}"
                                 behaviors:AutoScrollToCurrentItemBehavior.Enabled="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E9F3FF" />
                                            <Setter Property="Foreground" Value="#0E4A8A" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Width="64" Foreground="#777"
                                                   Text="{Binding Time, StringFormat={}{0:mm\\:ss}}" />
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" CornerRadius="12" Background="#111827" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="运行日志" Foreground="#E5E7EB" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />

                    <CheckBox Grid.Column="2" Content="INFO" Foreground="#93C5FD" IsChecked="{Binding ShowInfo, Mode=TwoWay}" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="4" Content="WARN" Foreground="#FCD34D" IsChecked="{Binding ShowWarn, Mode=TwoWay}" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="6" Content="ERROR" Foreground="#FCA5A5" IsChecked="{Binding ShowError, Mode=TwoWay}" VerticalAlignment="Center" />

                    <Button Grid.Column="8"
                            Content="清空日志"
                            Command="{Binding ClearLogsCommand}"
                            Padding="10,2"
                            Background="#374151"
                            Foreground="#E5E7EB"
                            BorderBrush="#4B5563" />
                </Grid>

                <Border Grid.Row="2" CornerRadius="8" Background="#0B1220" Padding="6">
                    <ListBox ItemsSource="{Binding FilteredLogEntries}"
                             SelectedItem="{Binding SelectedLogEntry, Mode=OneWay}"
                             behaviors:AutoScrollToCurrentItemBehavior.Enabled="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#D1D5DB"
                             FontFamily="Consolas"
                             FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
